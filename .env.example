# Postgres connection string (Neon / Supabase / Railway / local).
# If using Neon: use the POOLED endpoint (hostname has a "-pooler" suffix,
# shown as "Pooled connection" in the Neon dashboard), not the direct one.
# The collab server (server/) is a long-running process holding a Prisma
# connection open for its whole lifetime; Neon's free-tier compute
# auto-suspends on idle and force-closes direct connections when it does
# (Postgres error 57P01), which the pooled endpoint is designed to absorb.
DATABASE_URL="postgresql://user:password@localhost:5432/offline_collab_editor?schema=public"
# Direct (non-pooled) connection, used only for `prisma migrate`/`db push`.
# If your provider doesn't distinguish pooled vs direct, set this the same
# as DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/offline_collab_editor?schema=public"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# Short-lived JWT used to authorize the WebSocket collab server handshake
# Generate with: openssl rand -base64 32
COLLAB_JWT_SECRET="replace-with-a-different-random-32-byte-secret"

# Standalone WebSocket collab server (server/): port it listens on, and the
# URL the browser client connects to (run with: npm run server:dev)
COLLAB_SERVER_PORT="1234"
NEXT_PUBLIC_COLLAB_WS_URL="ws://localhost:1234"
